# Скопировать в .env.production и заполнить перед деплоем

# Секрет сессий: openssl rand -hex 32
AUTH_SECRET="ЗАМЕНИТЬ"

# Для временного запуска по http://IP:порт установите false.
# После подключения HTTPS обязательно измените на true.
AUTH_COOKIE_SECURE="true"

# Подтверждение телефона: smsru (пользователь звонит сам) или mock (код в логи)
OTP_PROVIDER="smsru"
SMSRU_API_ID="ЗАМЕНИТЬ"

# Telegram-бот (опционально)
TELEGRAM_BOT_TOKEN=""

# Web Push: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY="ЗАМЕНИТЬ"
VAPID_PRIVATE_KEY="ЗАМЕНИТЬ"
VAPID_SUBJECT="https://проектор7.рф"

# Сайт
NEXT_PUBLIC_SITE_URL="https://проектор7.рф"
APP_PORT="3002"
NEXT_PUBLIC_TELEGRAM_URL="https://t.me/USERNAME"
NEXT_PUBLIC_MAX_URL="https://max.ru/USERNAME"

# Защита крона ДР-пушей: openssl rand -hex 16
CRON_SECRET="ЗАМЕНИТЬ"
